# Backend server
NODE_ENV=production
PORT=5000

# Frontend domain allowed by CORS.
# Use your Vercel production URL. You can separate multiple origins with commas.
CLIENT_URL=https://your-frontend.vercel.app

# Auth token secret. Use a long random value in production.
AUTH_SECRET=replace-with-a-long-random-secret

# MySQL database
DB_HOST=your-production-db-host
DB_PORT=3306
DB_USER=your-production-db-user
DB_PASSWORD=your-production-db-password
DB_NAME=rendiweb_db
DB_CONNECTION_LIMIT=10

# Set true only if your MySQL provider requires TLS.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Request body limit for JSON/base64 uploads.
JSON_LIMIT=10mb
